extends layout

block content
	main.container.py-4
		.row.justify-content-center
			.col-12.col-lg-10.col-xl-8
				a.nav-link-secondary.mb-3(href="/")
					i.bi.bi-arrow-left.me-1
					| Back to Today

				.page-header
					h1 Chores
					a.btn.btn-chore.btn-sm(href="/chores/new") + New

				if chores.length === 0
					.empty-state
						.empty-state-icon
							i.bi.bi-wrench
						p No chores yet
						a.btn.btn-chore(href="/chores/new") Add your first
				else
					each chore in chores
						.chore-item
							.chore-item-content
								.chore-name= chore.title
								if chore.description
									.text-muted.small= chore.description
							.chore-item-actions
								a.btn.btn-sm.btn-outline-secondary(href=`/chores/${chore._id}/edit`) Edit
								form.d-inline(method="POST" action=`/chores/${chore._id}/delete` onsubmit="return confirm('Delete this chore?')")
									button.btn.btn-sm.btn-outline-danger(type="submit") Delete
