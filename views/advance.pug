extends layout

block content
	main.container.py-4
		- const birthdayCount = todaysBirthdays ? todaysBirthdays.length : 0
		- const scratchPadCount = scratchPadPrompt ? 1 : 0
		- const totalItems = rolloverTasks.length + recurringPrompts.length + birthdayCount + scratchPadCount

		if totalItems === 0
			.advance-card.card
				.card-body.text-center.py-5
					.empty-state-icon.mb-3
						i.bi.bi-stars
					h4 All caught up!
					p.text-muted.mb-4 No items to process
					a.btn.btn-primary(href="/") Go to Today
		else
			//- Escape hatches for large backlogs
			if rolloverTasks.length > 5
				.escape-hatches
					form(method="POST" action="/advance/bankruptcy")
						button.btn.btn-sm.btn-outline-danger(type="submit" onclick="return confirm('Archive all rollover tasks?')") Declare Bankruptcy
					form(method="POST" action="/advance/best-guess")
						button.btn.btn-sm.btn-outline-secondary(type="submit" onclick="return confirm('Move all tasks to today?')") Move All to Today

			//- Process rollover tasks first
			if rolloverTasks.length > 0
				- const task = rolloverTasks[currentIndex]
				.advance-card.card
					.card-header.advance-header-rollover
						span Rollover
						span.badge.bg-white.bg-opacity-25 #{rolloverTasks.length} left
					.card-body
						h4.mb-2= task.title
						if task.description
							p.text-muted.mb-3= task.description
						if task.scheduledFor
							.mb-3
								small.text-muted
									| Was scheduled for #{formatDate(task.scheduledFor)}
									if task.rollovers > 0
										|  · Deferred #{task.rollovers}×

						.advance-primary-actions
							form(method="POST" action=`/advance/${task._id}/complete`)
								button.btn.btn-success(type="submit")
									i.bi.bi-check-lg
									|  Done

							form(method="POST" action=`/advance/${task._id}/today`)
								button.btn.btn-primary(type="submit")
									i.bi.bi-sun
									|  Today

							form(method="POST" action=`/advance/${task._id}/defer`)
								input(type="hidden" name="date" value=tomorrowDateStr)
								button.btn.btn-outline-secondary(type="submit") Tomorrow

						.advance-schedule-section
							.advance-schedule-toggle(onclick="this.nextElementSibling.classList.toggle('show')")
								i.bi.bi-calendar-plus
								span Schedule for later
								i.bi.bi-chevron-down
							.advance-schedule-content
								.advance-quick-dates
									span.advance-quick-date(onclick="setScheduleDate(this, 7)") Next Week
									span.advance-quick-date(onclick="setScheduleDate(this, 30)") Next Month
								form.advance-schedule-form(method="POST" action=`/advance/${task._id}/defer`)
									input.form-control(type="date" name="date" required)
									button.btn.btn-outline-primary(type="submit") Schedule

						.advance-footer
							form(method="POST" action=`/advance/${task._id}/scratch`)
								button.btn.btn-outline-secondary(type="submit")
									i.bi.bi-sticky
									|  Scratch Pad
							form(method="POST" action=`/advance/${task._id}/archive`)
								button.btn.btn-outline-danger(type="submit") Archive

			//- Then process recurring prompts
			else if recurringPrompts.length > 0
				- const recurring = recurringPrompts[0]
				.advance-card.card
					.card-header.advance-header-recurring
						span Recurring
						span.badge.bg-white.bg-opacity-25 #{recurringPrompts.length} left
					.card-body
						h4.mb-2= recurring.title
						if recurring.description
							p.text-muted.mb-2= recurring.description
						.mb-3
							small.text-muted= recurring.getPatternDescription()

						.advance-primary-actions
							form(method="POST" action=`/advance/recurring/${recurring._id}/today`)
								button.btn.btn-primary(type="submit")
									i.bi.bi-plus-lg
									|  Today

							form(method="POST" action=`/advance/recurring/${recurring._id}/defer`)
								input(type="hidden" name="date" value=tomorrowDateStr)
								button.btn.btn-outline-secondary(type="submit") Tomorrow

							form(method="POST" action=`/advance/recurring/${recurring._id}/skip`)
								button.btn.btn-outline-secondary(type="submit")
									i.bi.bi-skip-forward
									|  Skip

						.advance-schedule-section
							.advance-schedule-toggle(onclick="this.nextElementSibling.classList.toggle('show')")
								i.bi.bi-calendar-plus
								span Schedule for later
								i.bi.bi-chevron-down
							.advance-schedule-content
								.advance-quick-dates
									span.advance-quick-date(onclick="setScheduleDate(this, 7)") Next Week
									span.advance-quick-date(onclick="setScheduleDate(this, 30)") Next Month
								form.advance-schedule-form(method="POST" action=`/advance/recurring/${recurring._id}/defer`)
									input.form-control(type="date" name="date" required)
									button.btn.btn-outline-primary(type="submit") Schedule

			//- Then process today's birthdays
			else if birthdayCount > 0
				- const person = todaysBirthdays[0]
				- const turningAge = person.getTurningAge(new Date())
				.advance-card.card
					.card-header.advance-header-birthday
						span Birthday
						span.badge.bg-white.bg-opacity-25 #{birthdayCount} left
					.card-body.text-center
						.birthday-emoji.mb-3
							i.bi.bi-cake2
						h3.mb-2 #{person.name}'s Birthday!
						if turningAge
							p.lead.mb-2 Turning #{turningAge} today
						if person.notes
							p.text-muted= person.notes
						.mt-4
							form(method="POST" action=`/advance/birthday/${person._id}/acknowledge`)
								button.btn.btn-birthday(type="submit") Got It

			//- Finally process scratch pad item
			else if scratchPadPrompt
				- const daysAgo = Math.floor((Date.now() - new Date(scratchPadPrompt.createdAt).getTime()) / (1000 * 60 * 60 * 24))
				.advance-card.card
					.card-header.advance-header-scratchpad
						span Scratch Pad
					.card-body
						h4.mb-2= scratchPadPrompt.title
						if scratchPadPrompt.description
							p.text-muted.mb-3= scratchPadPrompt.description
						.mb-3
							small.text-muted You jotted this down #{daysAgo} days ago. Still relevant?

						.advance-primary-actions
							form(method="POST" action=`/advance/scratchpad/${scratchPadPrompt._id}/today`)
								button.btn.btn-primary(type="submit")
									i.bi.bi-sun
									|  Today

							form(method="POST" action=`/advance/scratchpad/${scratchPadPrompt._id}/snooze`)
								button.btn.btn-outline-secondary(type="submit")
									i.bi.bi-sticky
									|  Keep

						.advance-schedule-section
							.advance-schedule-toggle(onclick="this.nextElementSibling.classList.toggle('show')")
								i.bi.bi-calendar-plus
								span Schedule for later
								i.bi.bi-chevron-down
							.advance-schedule-content
								.advance-quick-dates
									span.advance-quick-date(onclick="setScheduleDate(this, 7)") Next Week
									span.advance-quick-date(onclick="setScheduleDate(this, 30)") Next Month
								form.advance-schedule-form(method="POST" action=`/advance/scratchpad/${scratchPadPrompt._id}/defer`)
									input.form-control(type="date" name="date" required)
									button.btn.btn-outline-primary(type="submit") Schedule

						.advance-footer
							form(method="POST" action=`/advance/scratchpad/${scratchPadPrompt._id}/edit`)
								button.btn.btn-outline-secondary(type="submit")
									i.bi.bi-pencil
									|  Edit
							form(method="POST" action=`/advance/scratchpad/${scratchPadPrompt._id}/archive`)
								button.btn.btn-outline-danger(type="submit") Archive

block scripts
	script.
		function setScheduleDate(element, daysFromNow) {
			const date = new Date();
			date.setDate(date.getDate() + daysFromNow);
			const dateStr = date.toISOString().split('T')[0];
			const form = element.closest('.advance-schedule-content').querySelector('.advance-schedule-form');
			form.querySelector('input[type="date"]').value = dateStr;
		}

